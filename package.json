{
  "name": "noesis-server",
  "version": "0.1.0",
  "packageManager": "pnpm@11.5.0",
  "type": "module",
  "description": "Self-hosted documentation context engine — TypeScript server",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
  "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check --write src/",
    "test:ci": "mkdir -p test-results && vitest run --reporter=junit --outputFile=test-results/junit.xml --coverage",
    "test:integration": "vitest run test/integration --reporter=verbose",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrations.ts",
    "db:up": "docker compose -f infra/docker-compose.yml up -d postgres && docker compose -f infra/docker-compose.yml wait postgres && pnpm db:migrate",
    "db:down": "docker compose -f infra/docker-compose.yml down",
    "dev:ui": "pnpm --filter @noesis/ui dev",
    "dev:ui:build": "pnpm --filter @noesis/ui build",
    "dev:docker": "docker compose -f infra/docker-compose.yml up -d",
    "db:studio": "pnpm db:up && drizzle-kit studio",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@elastic/ecs-pino-format": "^1.5.0",
    "@fastify/cors": "^11.2.0",
    "@fastify/rate-limit": "^10.0.0",
    "@fastify/swagger": "^9.7.0",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@scalar/fastify-api-reference": "^1.60.0",
    "@xenova/transformers": "^2.17.2",
    "cheerio": "^1.0.0",
    "drizzle-orm": "^0.36.0",
    "fastify": "^5.2.2",
    "node-cron": "^3.0.3",
    "openai": "^6.42.0",
    "pg": "^8.14.1",
    "pino": "^10.3.1",
    "pino-seq": "^4.0.0",
    "playwright": "^1.52.0",
    "turndown": "^7.2.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.15.18",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.11.11",
    "@types/turndown": "^5.0.5",
    "@vitest/coverage-v8": "^2.1.9",
    "biome": "^0.3.3",
    "drizzle-kit": "^0.28.0",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^2.1.5"
  }
}
