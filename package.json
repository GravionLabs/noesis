{
  "name": "noesis",
  "version": "0.1.0",
  "packageManager": "pnpm@11.5.0",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "pnpm --filter @noesis/server build",
    "dev": "pnpm --filter @noesis/server dev",
    "start": "pnpm --filter @noesis/server start",
    "test": "pnpm --filter @noesis/server test",
    "test:watch": "pnpm --filter @noesis/server test:watch",
    "lint": "biome check --write apps/server/src/ apps/ui/src/",
    "test:ci": "pnpm --filter @noesis/server test:ci",
    "test:integration": "pnpm --filter @noesis/server test:integration",
    "typecheck": "pnpm --filter @noesis/server typecheck",
    "db:up": "docker compose -f infra/docker-compose.yml up -d postgres && docker compose -f infra/docker-compose.yml wait postgres && pnpm --filter @noesis/server db:migrate",
    "db:down": "docker compose -f infra/docker-compose.yml down",
    "dev:ui": "pnpm --filter @noesis/ui dev",
    "dev:ui:build": "pnpm --filter @noesis/ui build",
    "dev:docker": "docker compose -f infra/docker-compose.yml up -d",
    "dev:all": "concurrently -n server,ui -c cyan,green \"pnpm dev\" \"pnpm dev:ui\""
  },
  "devDependencies": {
    "biome": "^0.3.3",
    "concurrently": "^10.0.3"
  }
}
