{
  "$schema": "https://json.schemastore.org/launchsettings.json",
  "profiles": {
    "compose-ports": {
      "commandName": "Project",
      "dotnetRunMessages": true,
      "launchBrowser": false,
      "environmentVariables": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "ASPIRE_ALLOW_UNSECURED_TRANSPORT": "true",
        "APPHOST_INFRA_MODE": "external",
        "ASPNETCORE_URLS": "http://localhost:17148",
        "ASPIRE_DASHBOARD_OTLP_ENDPOINT_URL": "http://localhost:19213",
        "ASPIRE_DASHBOARD_OTLP_HTTP_ENDPOINT_URL": "http://localhost:20213"
      }
    },
    "aspire-infra": {
      "commandName": "Project",
      "dotnetRunMessages": true,
      "launchBrowser": false,
      "environmentVariables": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "ASPIRE_ALLOW_UNSECURED_TRANSPORT": "true",
        "APPHOST_INFRA_MODE": "managed",
        "ASPNETCORE_URLS": "http://localhost:17149",
        "ASPIRE_DASHBOARD_OTLP_ENDPOINT_URL": "http://localhost:19214",
        "ASPIRE_DASHBOARD_OTLP_HTTP_ENDPOINT_URL": "http://localhost:20214"
      }
    }
  }
}
