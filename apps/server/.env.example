# Copy this file to .env and adjust as needed.
# Source of truth: apps/server/src/config/index.ts

# Port the Fastify server listens on.
PORT=5000

# Postgres connection string (must have the pgvector extension installed).
DATABASE_URL=postgres://noesis:noesis_dev@localhost:5442/noesis

# Embedding provider: local, ollama, or openai.
EMBEDDING_PROVIDER=local

# Embedding model name. Used by all providers; must match dimensions below.
EMBEDDING_MODEL=Xenova/bge-base-en-v1.5

# Vector dimensions for the chosen embedding model.
EMBEDDING_DIMENSIONS=768

# Required when EMBEDDING_PROVIDER=openai.
OPENAI_API_KEY=

# Required when EMBEDDING_PROVIDER=ollama.
OLLAMA_URL=http://localhost:11434

# Used by the github importer/provider to authenticate against the GitHub API
# (raises rate limits, required for private repos).
GITHUB_TOKEN=

# Used by the azuredevops importer/provider.
AZURE_DEVOPS_TOKEN=
AZURE_DEVOPS_ORG=

# Shared secret required via the `x-api-key` header on /mcp and
# /api/internal/* routes. Empty (default) means those routes are
# UNAUTHENTICATED — set this for any non-localhost deployment.
API_KEY=

# Public base URL of this server, used in generated links/docs.
SERVER_URL=http://localhost:5000

# Log level: trace, debug, info, warn, error, fatal.
LOG_LEVEL=info

# Optional log sink: stdout (default), seq, or ecs.
LOG_SINK=stdout

# Seq server URL, used when LOG_SINK=seq.
SEQ_URL=http://localhost:5341

# Max retry attempts for a failed import job.
MAX_IMPORT_RETRIES=3

# Whether the server serves the built Angular UI as static files.
SERVE_UI=true

# Override the directory the UI is served from (defaults to the bundled
# apps/ui/dist/ui/browser build relative to the compiled server entrypoint).
UI_DIST_PATH=
