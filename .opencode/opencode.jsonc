{
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "git-workflow": {
      "description": "Creates branches and PRs per repo convention",
      "mode": "subagent",
      "model": "opencode/deepseek-v4-flash-free",
      "permission": {
        "bash": "allow",
        "edit": "allow"
      }
    }
  }
}
